# Lumi env. Copy to .env (the Expo CLI will load it automatically).
#
# Only Supabase's URL + anon key ship in the JS bundle. The Anthropic
# and OpenAI keys live ONLY as server-side secrets on the Supabase
# Edge Functions (anthropic-proxy, whisper-proxy) — they are NEVER
# in the client bundle. Set them with `supabase secrets set …`.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── Server-side secrets — set these on Supabase, NOT here ──
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-…
# supabase secrets set OPENAI_API_KEY=sk-…
