# Lumi env. Copy to .env (the Expo CLI will load it automatically).
# All keys are EXPO_PUBLIC_* so they ship in the JS bundle — only use
# anon/public credentials here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Anthropic key for Luna's check-ins. If you'd rather not ship a key in the
# bundle, leave this blank — Lumi will use built-in offline copy that still
# follows the same response shape.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
