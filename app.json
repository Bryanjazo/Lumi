{
  "expo": {
    "name": "Lumi",
    "slug": "lumi",
    "scheme": "lumi",
    "version": "1.1.17",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.lumi.ios",
      "usesAppleSignIn": true,
      "buildNumber": "29",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lumi uses your microphone so you can speak your check-ins instead of typing.",
        "NSSpeechRecognitionUsageDescription": "Lumi transcribes your voice to text on this device so Luna can respond.",
        "NSPhotoLibraryUsageDescription": "Lumi can use a photo from your library as your profile avatar.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.app.lumi.ios"]
      }
    },
    "android": {
      "package": "com.lumi.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#141210",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141210",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C4A0E0"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Lumi uses your microphone so you can speak your check-ins instead of typing.",
          "speechRecognitionPermission": "Lumi transcribes your voice to text on this device so Luna can respond."
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.921718778396-9anbj3agm6i6qon3j7pr3ln8nbgv8j8h"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Lumi adds tasks with times to your calendar so they show up alongside the rest of your day."
        }
      ],
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec38684c-3245-47a5-b0fe-ac3f0f14bce3"
      }
    },
    "owner": "bryanjazo88"
  }
}
