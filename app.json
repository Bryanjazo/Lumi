{
  "expo": {
    "name": "Lumi",
    "slug": "lumi",
    "scheme": "lumi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumi.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lumi uses your microphone so you can speak your check-ins instead of typing.",
        "NSSpeechRecognitionUsageDescription": "Lumi transcribes your voice to text so Luna can respond."
      }
    },
    "android": {
      "package": "com.lumi.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#141210",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141210",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C4A0E0"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
